# Copy to .env and fill in. .env is gitignored — never commit it.

# Apify — https://console.apify.com/account/integrations
APIFY_TOKEN=

# Telegram bot for the daily digest (create via @BotFather, then DM the bot once)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DeepSeek — classify/extract (deepseek-v4-flash) + eARC verdict (deepseek-v4-pro)
DEEPSEEK_API_KEY=

# Kagi — FastGPT web research for eARC lookups (https://kagi.com/settings?p=api)
# FastGPT (/api/v0) needs a Kagi *v0* API token (Authorization: Bot <token>).
KAGI_V0_API_KEY=
# v1 token (kept for reference / future v1 endpoints; not used by FastGPT)
KAGI_API_KEY=
# Optional — zero-code v0->v1 cutover for the eARC research endpoint:
#   KAGI_FASTGPT_URL  default https://kagi.com/api/v0/fastgpt
#   KAGI_TOKEN        explicit token (else falls back to KAGI_V0_API_KEY, then KAGI_API_KEY)
# To move to v1 (when FastGPT ships on v1 / v0 credits run out), uncomment + set both:
# KAGI_FASTGPT_URL=https://kagi.com/api/v1/fastgpt
# KAGI_TOKEN=

# Gemini — vision model-extraction for unconfirmed receivers (reads photos for a model number)
GEMINI_API_KEY=
# Optional overrides:
# GEMINI_VISION_MODEL=gemini-2.5-flash-lite
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
